{
  "name": "workhubmvc",
  "version": "1.1.0",
  "description": "WorkHub — Co-working Space booking (Node.js, Express, EJS, MongoDB) with hardened auth and ownership checks.",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --runInBand --detectOpenHandles --testTimeout=90000",
    "test:noforce": "jest --runInBand --detectOpenHandles --testTimeout=90000",
    "test:force": "jest --runInBand --detectOpenHandles --forceExit",
    "test:ci": "jest --runInBand --detectOpenHandles --testTimeout=90000",
    "test:open": "jest --runInBand --detectOpenHandles --testTimeout=90000",
    "test:watch": "jest --watch --runInBand",
    "lint": "eslint app.js server.js config middlewares services jobs utils routes controllers models test scripts public/js --max-warnings=0",
    "lint:security-ui": "node scripts/check-inline-handlers.js",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"config/**/*.js\" \"services/**/*.js\" \"middlewares/**/*.js\" \"scripts/**/*.js\" \"test/master-production-*.test.js\"",
    "test:transactions": "cross-env ENABLE_TRANSACTIONS=true jest --runInBand --detectOpenHandles --testTimeout=120000 test/finance-transactions.test.js test/webhook-transactions.test.js test/booking-transactions.test.js test/membership-transactions.test.js",
    "check": "npm run lint:security-ui && npm run lint && npm test",
    "migrate:fields": "node scripts/migrateCanonicalFields.js --dry-run",
    "seed:extras": "node scripts/seedDemoExtras.js",
    "backup": "node scripts/backup-mongo.js",
    "sbom": "node scripts/generate-sbom.js",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "build:css": "node scripts/purge-css.js",
    "build:css:full": "node scripts/minify-css.js",
    "smoke": "node scripts/smoke-e2e.js",
    "load:smoke": "node scripts/load-smoke.js",
    "test:e2e": "node scripts/playwright-e2e.js",
    "reconcile:finance": "node scripts/reconcile-finance.js",
    "jobs:expire-holds": "node scripts/expire-holds.js",
    "worker": "node scripts/expire-holds.js",
    "build:assets": "node scripts/build-assets.js",
    "build": "npm run build:css && npm run build:assets",
    "seed:content": "node scripts/seedContentPages.js",
    "indexes:verify": "node scripts/indexes-verify.js",
    "test:responsive": "node scripts/responsive-check.js"
  },
  "keywords": [
    "coworking",
    "express",
    "mongodb",
    "workhub"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20.19.0 <21 || >=22.13.0"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@simplewebauthn/server": "^13.3.2",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "socket.io": "^4.8.3",
    "stripe": "^17.7.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "jsdom": "^29.1.1",
    "mongodb-memory-server": "^10.3.0",
    "nodemon": "^3.1.11",
    "playwright": "^1.61.1",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4"
  },
  "overrides": {
    "cloudinary": "$cloudinary",
    "exceljs": {
      "uuid": "^11.1.1"
    }
  }
}
