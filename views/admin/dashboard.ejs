<div class="p-6 space-y-6">
    <div class="mb-4">
        <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Bảng Điều Khiển Quản Trị</h2>
        <p class="text-slate-500 text-sm mt-1">Theo dõi toàn cảnh sức khỏe hệ thống WorkHub</p>
    </div>

    <div class="bg-white p-2.5 rounded-[2rem] shadow-sm border border-slate-100 flex items-center relative z-50 w-full lg:w-max mb-6">
        <div class="relative inline-block text-left w-full sm:w-auto" id="custom-time-dropdown">
            <button type="button" id="custom-time-btn" class="flex items-center gap-2 bg-white border border-slate-200 rounded-full px-4 py-2 text-sm font-bold text-slate-700 hover:border-teal-500 transition shadow-sm outline-none justify-center min-w-[170px]">
                <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                <span id="custom-time-text">Tất cả thời gian</span>
            </button>
            <div id="custom-time-menu" class="hidden absolute left-0 mt-2 w-56 bg-white rounded-2xl shadow-xl border border-slate-100 z-50 overflow-hidden transform opacity-0 scale-95 transition-all duration-200 origin-top-left">
                <div class="py-2 flex flex-col">
                    <button type="button" class="time-option-btn w-full text-left px-5 py-3 text-sm font-bold text-teal-600 hover:bg-slate-50 transition" data-value="all">Tất cả thời gian</button>
                    <button type="button" class="time-option-btn w-full text-left px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 transition" data-value="specific">Ngày cụ thể...</button>
                    <button type="button" class="time-option-btn w-full text-left px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 transition" data-value="range">Khoảng thời gian...</button>
                </div>
            </div>
        </div>
        <div class="absolute w-0 h-0 overflow-hidden opacity-0 pointer-events-none">
            <input type="date" id="filter-date-1">
            <input type="date" id="filter-date-2">
        </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div class="bg-emerald-50 border border-emerald-100 p-4 rounded-2xl"><h3 class="text-emerald-600 text-[10px] font-black uppercase">Người dùng</h3><p id="stat-users" class="text-2xl font-black text-emerald-800 mt-1">0</p></div>
        <div class="bg-indigo-50 border border-indigo-100 p-4 rounded-2xl"><h3 class="text-indigo-600 text-[10px] font-black uppercase">Chủ cơ sở</h3><p id="stat-hosts" class="text-2xl font-black text-indigo-800 mt-1">0</p></div>
        <div class="bg-blue-50 border border-blue-100 p-4 rounded-2xl"><h3 class="text-blue-600 text-[10px] font-black uppercase">Chi nhánh</h3><p id="stat-branches" class="text-2xl font-black text-blue-800 mt-1">0</p></div>
        <div class="bg-purple-50 border border-purple-100 p-4 rounded-2xl"><h3 class="text-purple-600 text-[10px] font-black uppercase">Không gian</h3><p id="stat-spaces" class="text-2xl font-black text-purple-800 mt-1">0</p></div>
        <div class="bg-amber-50 border border-amber-100 p-4 rounded-2xl"><h3 class="text-amber-600 text-[10px] font-black uppercase">Lượt đặt chỗ</h3><p id="stat-bookings" class="text-2xl font-black text-amber-800 mt-1">0</p></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm lg:col-span-2">
            <h3 class="text-slate-800 font-bold mb-4">Xu hướng Doanh thu (VND)</h3>
            <canvas id="revenueLineChart" height="100"></canvas>
        </div>
        <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm h-fit">
            <h3 class="text-slate-800 font-bold mb-4 flex justify-between items-center">
                Nhật ký hoạt động 
                <a href="/admin/activitylog" class="text-[10px] text-teal-600 font-bold uppercase hover:underline">Xem thêm</a>
            </h3>
            <div id="audit-log-container" class="space-y-3"></div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm h-fit">
            <h3 class="text-slate-800 font-bold mb-4">Trạng thái Đơn đặt chỗ</h3>
            <div class="relative h-[250px] w-full flex items-center justify-center">
                <canvas id="bookingStatusChart"></canvas>
            </div>
        </div>
        <div class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm h-fit">
            <h3 class="text-slate-800 font-bold mb-4">Top đối tác (Doanh thu)</h3>
            <div id="top-hosts-container" class="space-y-2"></div>
        </div>
    </div>
</div>
<script src="/socket.io/socket.io.js"></script> <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
