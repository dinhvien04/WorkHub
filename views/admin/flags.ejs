<div class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-black mb-2">Feature flags</h1>
  <p class="text-sm text-slate-500 mb-4">Kill switch / percentage rollout / role scope.</p>
  <div class="bg-white rounded-3xl border p-5 mb-4 grid gap-3">
    <input id="flag-key" class="border rounded-xl px-3 py-2 text-sm" placeholder="flag_key" />
    <input id="flag-desc" class="border rounded-xl px-3 py-2 text-sm" placeholder="Mô tả" />
    <div class="flex gap-3 items-center">
      <label class="text-sm flex items-center gap-2"><input type="checkbox" id="flag-enabled" checked /> Enabled</label>
      <label class="text-sm">% <input type="number" id="flag-pct" value="100" min="0" max="100" class="border rounded-lg w-20 px-2 py-1" /></label>
    </div>
    <button type="button" id="flag-save" class="bg-teal-600 text-white px-5 py-2 rounded-xl text-xs font-black uppercase w-fit">Upsert</button>
  </div>
  <p id="flag-msg" class="text-sm mb-3" role="status"></p>
  <div id="flag-list" class="bg-white rounded-3xl border overflow-hidden"></div>
</div>
