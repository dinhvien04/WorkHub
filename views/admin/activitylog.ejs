<div class="p-6 space-y-6">
    <div class="mb-4">
        <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Nhật ký hoạt động</h2>
    </div>

    <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm flex flex-wrap items-center gap-4">
        <div class="relative inline-block text-left w-full sm:w-auto" id="custom-time-dropdown">
            <button type="button" id="custom-time-btn" class="flex items-center gap-2 bg-white border border-slate-200 rounded-full px-4 py-2 text-sm font-bold text-slate-700 hover:border-teal-500 transition shadow-sm outline-none justify-center min-w-[170px]">
                <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                <span id="custom-time-text">Tất cả thời gian</span>
            </button>
            <div id="custom-time-menu" class="hidden absolute left-0 mt-2 w-56 bg-white rounded-2xl shadow-xl border border-slate-100 z-50 overflow-hidden transform opacity-0 scale-95 transition-all duration-200 origin-top-left">
                <div class="py-2 flex flex-col">
                    <button type="button" class="time-option-btn w-full text-left px-5 py-3 text-sm font-bold text-teal-600 hover:bg-slate-50 transition" data-value="all">Tất cả thời gian</button>
                    <button type="button" class="time-option-btn w-full text-left px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 transition" data-value="specific">Ngày cụ thể...</button>
                    <button type="button" class="time-option-btn w-full text-left px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 transition" data-value="range">Khoảng thời gian...</button>
                </div>
            </div>
        </div>
        <div class="absolute w-0 h-0 overflow-hidden opacity-0 pointer-events-none">
            <input type="date" id="filter-date-1">
            <input type="date" id="filter-date-2">
        </div>

        <div class="flex-1 min-w-[200px] relative">
            <input type="text" id="filter-keyword" placeholder="Tìm kiếm theo mô tả, tên, ID..." class="w-full pl-4 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-full text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:bg-white transition">
        </div>

        <select id="filter-entity" class="bg-white border border-slate-200 text-slate-700 text-sm font-bold rounded-full px-4 py-2 focus:outline-none focus:ring-2 focus:ring-teal-500 shadow-sm cursor-pointer">
            <option value="all">Tất cả đối tượng</option>
            <option value="Booking">Đơn đặt chỗ (Booking)</option>
            <option value="User">Tài khoản (User/Profile)</option>
            <option value="Space">Không gian (Space/Branch)</option>
            <option value="PaymentHistory">Giao dịch (Payment)</option>
        </select>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[900px]">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-xs uppercase tracking-wider text-slate-500 font-bold">
                        <th class="p-4 w-40">Thời gian</th>
                        <th class="p-4 w-48">Người thực hiện</th>
                        <th class="p-4 w-40">Hành động</th>
                        <th class="p-4 min-w-[250px]">Nội dung</th>
                        
                    </tr>
                </thead>
                <tbody id="activity-log-table-body" class="text-sm divide-y divide-slate-50">
                    <tr><td colspan="5" class="p-8 text-center text-slate-400 font-medium">Đang tải dữ liệu...</td></tr>
                </tbody>
            </table>
        </div>
        
        <div class="p-4 border-t border-slate-100 flex items-center justify-between text-sm text-slate-600 font-medium" id="pagination-container">
            </div>
    </div>
</div>
<div id="detail-modal" class="hidden fixed inset-0 z-[100] bg-slate-900/50 backdrop-blur-sm flex items-center justify-center p-4 transition-opacity opacity-0">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden transform scale-95 transition-all" id="detail-modal-content">
        <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
            <h3 class="text-lg font-black text-slate-800" id="modal-title">Chi tiết hoạt động</h3>
            <button data-wh-click="closeDetailsModal" class="text-slate-400 hover:text-red-500 transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="p-6">
            <div id="modal-body" class="space-y-4 text-sm text-slate-600">
                </div>
        </div>
        <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex justify-end">
            <button data-wh-click="closeDetailsModal" class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold rounded-lg transition">Đóng</button>
        </div>
    </div>
</div>