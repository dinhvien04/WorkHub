<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : 'WorkHub - Đặt chỗ Co-working' %></title>
    <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'WorkHub — tìm và đặt chỗ co-working, phòng họp.' %>">
    <link rel="canonical" href="<%= (typeof req !== 'undefined' && req.protocol && req.get) ? (req.protocol + '://' + req.get('host') + (typeof canonicalPath !== 'undefined' ? canonicalPath : req.path)) : '/' %>">
    <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'WorkHub' %>">
    <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Đặt chỗ co-working trên WorkHub' %>">
    <meta property="og:type" content="website">
    <% if (typeof ogImage !== 'undefined' && ogImage) { %>
    <meta property="og:image" content="<%= ogImage %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="<%= ogImage %>">
    <% } else { %>
    <meta name="twitter:card" content="summary">
    <% } %>
    <meta name="twitter:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'WorkHub' %>">
    <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Đặt chỗ co-working trên WorkHub' %>">
    <meta name="theme-color" content="#0d9488">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" href="/icons/icon.svg" type="image/svg+xml">
    <meta name="apple-mobile-web-app-capable" content="yes">

    <% if (typeof useTailwindCdn === 'undefined' || useTailwindCdn) { %>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <% } else { %>
    <% /* Prefer minified bundle when present (npm run build:css) */ %>
    <% /* Built CSS required in production (npm run build:css); no inline onerror fallback */ %>
    <link rel="stylesheet" href="/css/app.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <% } %>
    <% if (typeof loadChartJs !== 'undefined' && loadChartJs) { %>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js" defer></script>
    <% } %>
    <% if (typeof loadChoices !== 'undefined' && loadChoices) { %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">
    <% } %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
      <% const _ld = Array.isArray(jsonLd) ? jsonLd : [jsonLd]; %>
      <% _ld.forEach(function(block) { %>
    <script type="application/ld+json" nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>"><%- JSON.stringify(block) %></script>
      <% }); %>
    <% } %>
</head>
<body class="antialiased text-slate-800">
    <a class="skip-link" href="#main-content">Bỏ qua điều hướng</a>
    <% if (typeof loadSocket !== 'undefined' && loadSocket) { %>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="/socket.io/socket.io.js" defer></script>
    <% } %>
    <div class="app-wrapper">
        <%- include('partials/header') %>
        <div class="main-container">
            <%- include('partials/sidebar') %>
            <main class="content-area" id="main-content" tabindex="-1">
                <%- body %>
            </main>
        </div>
    </div>

    <%- include('partials/modals') %>

    <% if (typeof loadChoices !== 'undefined' && loadChoices) { %>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js" defer></script>
    <% } %>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="/js/api.js"></script>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="/js/domSafe.js"></script>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="/js/i18n.js"></script>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="/js/main.js"></script>
    <%- typeof scripts !== 'undefined' ? scripts : '' %>
    <nav class="mobile-bottom-nav" aria-label="Điều hướng mobile">
      <a href="/" class="mob-nav-item" data-nav="home">🏠<span>Khám phá</span></a>
      <a href="/history" class="mob-nav-item" data-nav="history">📅<span>Lịch đặt</span></a>
      <a href="/favorites" class="mob-nav-item" data-nav="favorites">❤️<span>Yêu thích</span></a>
      <a href="/notifications" class="mob-nav-item relative" data-nav="notifications">🔔<span>Thông báo</span><span id="mob-notif-badge" class="hidden absolute top-0 right-2 min-w-[16px] h-4 px-1 rounded-full bg-red-500 text-white text-[9px] font-black leading-4 text-center">0</span></a>
      <a href="/profile" class="mob-nav-item" data-nav="profile">👤<span>Tài khoản</span></a>
    </nav>
    <div id="pwa-install-bar" class="hidden fixed bottom-20 md:bottom-4 left-1/2 -translate-x-1/2 z-[90] max-w-md w-[calc(100%-2rem)] bg-slate-900 text-white rounded-2xl shadow-xl px-4 py-3 flex items-center gap-3" role="dialog" aria-label="Cài đặt app">
      <div class="flex-1 text-sm">
        <p class="font-bold">Cài WorkHub</p>
        <p class="text-xs text-slate-300">Truy cập nhanh như app, hỗ trợ offline shell.</p>
      </div>
      <button type="button" id="pwa-install-btn" class="text-xs font-black uppercase bg-teal-500 px-3 py-2 rounded-xl">Cài</button>
      <button type="button" id="pwa-install-dismiss" class="text-xs text-slate-400" aria-label="Đóng">✕</button>
    </div>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>">
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').then(function (reg) {
            if (reg.waiting) {
              reg.waiting.postMessage({ type: 'SKIP_WAITING' });
            }
            reg.addEventListener('updatefound', function () {
              var nw = reg.installing;
              if (!nw) return;
              nw.addEventListener('statechange', function () {
                if (nw.state === 'installed' && navigator.serviceWorker.controller) {
                  nw.postMessage({ type: 'SKIP_WAITING' });
                }
              });
            });
          }).catch(function () {});
        });
      }
      (function pwaInstall() {
        var deferred = null;
        var bar = document.getElementById('pwa-install-bar');
        var btn = document.getElementById('pwa-install-btn');
        var dismiss = document.getElementById('pwa-install-dismiss');
        if (!bar) return;
        try {
          if (localStorage.getItem('pwaInstallDismissed') === '1') return;
        } catch (e) {}
        window.addEventListener('beforeinstallprompt', function (e) {
          e.preventDefault();
          deferred = e;
          bar.classList.remove('hidden');
        });
        btn && btn.addEventListener('click', function () {
          if (!deferred) return;
          deferred.prompt();
          deferred.userChoice.finally(function () {
            deferred = null;
            bar.classList.add('hidden');
          });
        });
        dismiss && dismiss.addEventListener('click', function () {
          bar.classList.add('hidden');
          try { localStorage.setItem('pwaInstallDismissed', '1'); } catch (e) {}
        });
      })();
      // Lightweight RUM beacon (LCP/CLS/INP) — no PII
      (function () {
        var sent = false;
        function send(partial) {
          if (sent) return;
          sent = true;
          var body = {
            path: location.pathname.slice(0, 200),
            navType: (performance.getEntriesByType && performance.getEntriesByType('navigation')[0] || {}).type || '',
            lcp: partial.lcp || null,
            cls: partial.cls || null,
            inp: partial.inp || null,
            ttfb: partial.ttfb || null,
            fcp: partial.fcp || null
          };
          try {
            if (navigator.sendBeacon) {
              navigator.sendBeacon('/api/rum', new Blob([JSON.stringify(body)], { type: 'application/json' }));
            } else {
              fetch('/api/rum', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body), keepalive: true });
            }
          } catch (e) {}
        }
        try {
          var cls = 0;
          if ('PerformanceObserver' in window) {
            try {
              new PerformanceObserver(function (list) {
                list.getEntries().forEach(function (e) {
                  if (!e.hadRecentInput) cls += e.value;
                });
              }).observe({ type: 'layout-shift', buffered: true });
            } catch (e) {}
            try {
              new PerformanceObserver(function (list) {
                var entries = list.getEntries();
                var last = entries[entries.length - 1];
                if (last) send({ lcp: last.startTime, cls: cls });
              }).observe({ type: 'largest-contentful-paint', buffered: true });
            } catch (e) {}
          }
          window.addEventListener('pagehide', function () { send({ cls: cls }); });
          setTimeout(function () { send({ cls: cls }); }, 8000);
        } catch (e) {}
      })();
    </script>
</body>
</html>
