<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : 'WorkHub - Đặt chỗ Co-working' %></title>
    <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'WorkHub — tìm và đặt chỗ co-working, phòng họp.' %>">
    <link rel="canonical" href="<%= (typeof req !== 'undefined' && req.protocol && req.get) ? (req.protocol + '://' + req.get('host') + (typeof canonicalPath !== 'undefined' ? canonicalPath : req.path)) : '/' %>">
    <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'WorkHub' %>">
    <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Đặt chỗ co-working trên WorkHub' %>">
    <meta property="og:type" content="website">
    <meta name="theme-color" content="#0d9488">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" href="/icons/icon.svg" type="image/svg+xml">
    <meta name="apple-mobile-web-app-capable" content="yes">

    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="https://cdn.tailwindcss.com"></script>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js" defer></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
    <script type="application/ld+json" nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>"><%- JSON.stringify(jsonLd) %></script>
    <% } %>
</head>
<body class="antialiased text-slate-800">
    <a class="skip-link" href="#main-content">Bỏ qua điều hướng</a>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="/socket.io/socket.io.js"></script>
    <div class="app-wrapper">
        <%- include('partials/header') %>
        <div class="main-container">
            <%- include('partials/sidebar') %>
            <main class="content-area" id="main-content">
                <%- body %>
            </main>
        </div>
    </div>

    <%- include('partials/modals') %>

    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js" defer></script>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="/js/api.js"></script>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="/js/domSafe.js"></script>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>" src="/js/main.js"></script>
    <%- typeof scripts !== 'undefined' ? scripts : '' %>
    <nav class="mobile-bottom-nav" aria-label="Điều hướng mobile">
      <a href="/" class="mob-nav-item" data-nav="home">🏠<span>Khám phá</span></a>
      <a href="/history" class="mob-nav-item" data-nav="history">📅<span>Lịch đặt</span></a>
      <a href="/favorites" class="mob-nav-item" data-nav="favorites">❤️<span>Yêu thích</span></a>
      <a href="/notifications" class="mob-nav-item" data-nav="notifications">🔔<span>Thông báo</span></a>
      <a href="/profile" class="mob-nav-item" data-nav="profile">👤<span>Tài khoản</span></a>
    </nav>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>">
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {});
        });
      }
    </script>
</body>
</html>
