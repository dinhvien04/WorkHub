<div class="max-w-2xl mx-auto">
  <a href="/history" class="text-teal-700 text-sm font-bold hover:underline">← Lịch sử đặt</a>
  <h1 class="text-2xl font-black mt-2 mb-1">Chi tiết booking</h1>
  <p id="bd-id" class="text-xs text-slate-400 font-mono mb-4"></p>

  <div id="bd-error" class="hidden text-red-600 text-sm mb-3" role="alert"></div>

  <section class="bg-white rounded-3xl border p-5 mb-4">
    <div id="bd-summary" class="space-y-1 text-sm"></div>
    <p id="bd-hold" class="hidden mt-3 text-sm font-bold text-amber-700 bg-amber-50 border border-amber-100 rounded-xl px-3 py-2" role="status" aria-live="polite"></p>
    <div id="bd-policy" class="mt-3 text-xs text-slate-500 border-t pt-3"></div>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-4">
    <h2 class="font-bold mb-2">Thanh toán</h2>
    <p id="bd-pay" class="text-sm"></p>
    <a id="bd-pay-link" href="#" class="hidden inline-block mt-2 text-xs font-black uppercase bg-teal-600 text-white px-3 py-2 rounded-xl">Thanh toán / cọc</a>
    <a id="bd-receipt" href="#" class="text-xs font-black uppercase text-teal-700 hidden ml-2">Biên lai</a>
  </section>

  <section id="bd-reschedule-section" class="bg-white rounded-3xl border p-5 mb-4 hidden">
    <h2 class="font-bold mb-2">Đổi lịch</h2>
    <p class="text-xs text-slate-500 mb-3">Server kiểm tra chỗ trống trước; chỉ áp dụng khi khung giờ mới free. Slot cũ không giải phóng nếu giữ slot mới thất bại.</p>
    <div class="grid sm:grid-cols-2 gap-3 mb-3">
      <div>
        <label class="text-[10px] font-black uppercase text-slate-400" for="bd-rs-start">Bắt đầu (ISO local)</label>
        <input id="bd-rs-start" type="datetime-local" class="w-full border rounded-xl px-3 py-2 text-sm" />
      </div>
      <div>
        <label class="text-[10px] font-black uppercase text-slate-400" for="bd-rs-end">Kết thúc</label>
        <input id="bd-rs-end" type="datetime-local" class="w-full border rounded-xl px-3 py-2 text-sm" />
      </div>
    </div>
    <div class="flex flex-wrap gap-2 mb-2">
      <button type="button" id="bd-rs-preview" class="px-3 py-2 rounded-xl bg-slate-800 text-white text-xs font-bold">Xem trước</button>
      <button type="button" id="bd-rs-apply" class="px-3 py-2 rounded-xl bg-teal-600 text-white text-xs font-bold" disabled>Áp dụng đổi lịch</button>
    </div>
    <div id="bd-rs-preview-box" class="text-sm text-slate-600 space-y-1"></div>
    <p id="bd-rs-msg" class="text-sm mt-2" role="status"></p>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-4">
    <h2 class="font-bold mb-2">Timeline</h2>
    <ol id="bd-timeline" class="space-y-2 text-sm"></ol>
  </section>

  <section id="bd-checkin-section" class="bg-white rounded-3xl border p-5 mb-4 hidden">
    <h2 class="font-bold mb-2">Check-in QR</h2>
    <p class="text-xs text-slate-500 mb-3">Mã ngắn hạn cho lễ tân. Chỉ hiện khi booking confirmed/in-use.</p>
    <div class="flex flex-wrap gap-2 items-center">
      <button type="button" id="bd-qr-btn" class="bg-teal-600 text-white text-xs font-black uppercase px-4 py-2 rounded-xl">Tạo mã QR</button>
      <span id="bd-qr-code" class="text-lg font-black tracking-widest text-teal-700"></span>
    </div>
    <img id="bd-qr-img" alt="" width="180" height="180" class="mt-3 hidden rounded-xl border" />
    <p id="bd-qr-exp" class="text-xs text-slate-400 mt-2"></p>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-4">
    <h2 class="font-bold mb-2">Lịch</h2>
    <div class="flex flex-wrap gap-2">
      <a id="bd-gcal" target="_blank" rel="noopener" class="text-xs font-black uppercase bg-slate-800 text-white px-3 py-2 rounded-xl">Google</a>
      <a id="bd-outlook" target="_blank" rel="noopener" class="text-xs font-black uppercase border px-3 py-2 rounded-xl">Outlook</a>
      <a id="bd-ics" class="text-xs font-black uppercase border border-teal-300 text-teal-800 px-3 py-2 rounded-xl">ICS</a>
    </div>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-4">
    <h2 class="font-bold mb-2">Hủy đặt chỗ</h2>
    <p id="bd-cancel-preview" class="text-sm text-slate-600 mb-2"></p>
    <button type="button" id="bd-cancel-btn"
      class="bg-red-600 text-white px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest">
      Hủy booking
    </button>
    <p id="bd-cancel-msg" class="text-sm mt-2" role="status"></p>
  </section>
</div>
