<div class="max-w-lg mx-auto" id="rsvp-page" data-token="<%= typeof token !== 'undefined' ? token : '' %>">
  <h1 class="text-2xl font-black text-slate-800 mb-2">RSVP lời mời</h1>
  <p class="text-sm text-slate-500 mb-6">Xác nhận tham dự buổi đặt chỗ WorkHub.</p>
  <div id="rsvp-error" class="error-state hidden mb-4" role="alert"></div>
  <section class="bg-white rounded-3xl border p-6 mb-4">
    <div id="rsvp-info" class="space-y-1 text-sm text-slate-700"></div>
    <p id="rsvp-status" class="mt-3 text-sm font-bold text-teal-700"></p>
  </section>
  <div class="flex gap-2">
    <button type="button" id="rsvp-yes" class="flex-1 btn-primary">Tham dự</button>
    <button type="button" id="rsvp-no" class="flex-1 py-2 rounded-xl border font-bold text-sm text-red-600">Từ chối</button>
  </div>
  <div id="rsvp-cal" class="mt-4 flex flex-wrap gap-2 hidden"></div>
</div>
