<div class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-black mb-2" data-i18n="dash.title">Tổng quan</h1>
  <p class="text-sm text-slate-500 mb-6" data-i18n="dash.subtitle">Booking sắp tới, việc cần làm và thanh toán chờ xác minh.</p>

  <div id="dash-counts" class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-6"></div>

  <section class="bg-white rounded-3xl border p-5 mb-4">
    <h2 class="font-bold mb-3" data-i18n="dash.checkin">Check-in hôm nay</h2>
    <p class="text-xs text-slate-500 mb-3">Mã QR ngắn hạn (30 phút). Host quét tại lễ tân hoặc nhập mã WH-xxxxxx.</p>
    <div id="dash-checkin" class="space-y-3 text-sm"></div>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-4">
    <h2 class="font-bold mb-3" data-i18n="booking.action_required">Cần xử lý</h2>
    <div id="dash-action" class="space-y-2 text-sm"></div>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-4">
    <h2 class="font-bold mb-3" data-i18n="booking.upcoming">Sắp tới</h2>
    <div id="dash-upcoming" class="space-y-2 text-sm"></div>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-4">
    <h2 class="font-bold mb-3">Thanh toán chờ host</h2>
    <div id="dash-pay" class="space-y-2 text-sm"></div>
  </section>
</div>

<!-- Check-in QR modal -->
<div id="dash-qr-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4" role="dialog" aria-modal="true" aria-label="Check-in QR">
  <div class="bg-white rounded-3xl shadow-2xl w-full max-w-sm p-6 text-center relative">
    <button type="button" id="dash-qr-close" class="absolute top-3 right-3 w-9 h-9 rounded-full bg-slate-100 font-bold" aria-label="Đóng">&times;</button>
    <h3 class="font-black text-lg mb-1" data-i18n="booking.checkin_qr">Mã check-in</h3>
    <p id="dash-qr-title" class="text-sm text-slate-500 mb-3"></p>
    <img id="dash-qr-img" alt="QR check-in" width="200" height="200" class="mx-auto rounded-xl border mb-3" />
    <p id="dash-qr-code" class="text-2xl font-black tracking-widest text-teal-700 mb-1"></p>
    <p id="dash-qr-exp" class="text-xs text-slate-400 mb-3"></p>
    <button type="button" id="dash-qr-copy" class="text-xs font-bold uppercase text-teal-700 border border-teal-200 px-3 py-2 rounded-xl">Copy token</button>
  </div>
</div>
