<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-black mb-2">Bảo mật tài khoản</h1>
  <p class="text-sm text-slate-500 mb-6">2FA, phiên đăng nhập, thông báo và quyền riêng tư.</p>

  <section class="bg-white rounded-3xl border p-5 mb-6">
    <h2 class="font-bold mb-3">Passkey (WebAuthn)</h2>
    <p class="text-sm text-slate-500 mb-2">Đăng nhập bằng vân tay / khuôn mặt / security key khi trình duyệt hỗ trợ.</p>
    <button type="button" id="passkey-register-btn"
      class="bg-slate-800 text-white px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest mb-3">
      Đăng ký passkey
    </button>
    <div id="passkey-list" class="space-y-2"></div>
    <p id="passkey-msg" class="text-sm mt-2" role="status"></p>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-6">
    <h2 class="font-bold mb-3">Xác thực hai lớp (TOTP)</h2>
    <p id="totp-status" class="text-sm text-slate-600 mb-3">Đang tải…</p>
    <div class="flex flex-wrap gap-2">
      <button type="button" id="totp-setup-btn"
        class="bg-teal-600 text-white px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-teal-700">
        Thiết lập 2FA
      </button>
      <button type="button" id="totp-enable-btn"
        class="bg-slate-800 text-white px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-slate-900 hidden">
        Xác nhận mã &amp; bật
      </button>
      <button type="button" id="totp-disable-btn"
        class="border border-red-300 text-red-700 px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-red-50 hidden">
        Tắt 2FA
      </button>
    </div>
    <pre id="totp-secret" class="mt-3 text-xs bg-slate-50 p-3 rounded-xl overflow-x-auto hidden"></pre>
    <p id="totp-msg" class="text-sm mt-2" role="status"></p>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-6">
    <div class="flex items-center justify-between gap-3 mb-4">
      <h2 class="font-bold">Phiên đăng nhập</h2>
      <button type="button" id="logout-all-btn"
        class="bg-red-600 text-white px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-red-700">
        Đăng xuất tất cả
      </button>
    </div>
    <p id="sec-msg" class="text-sm mb-3" role="status"></p>
    <div id="session-list" class="space-y-2"></div>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-6">
    <h2 class="font-bold mb-3">Tùy chọn thông báo & ngôn ngữ</h2>
    <label class="flex items-center gap-2 text-sm mb-2"><input type="checkbox" id="pref-email" /> Email</label>
    <label class="flex items-center gap-2 text-sm mb-2"><input type="checkbox" id="pref-push" /> Push</label>
    <label class="flex items-center gap-2 text-sm mb-2"><input type="checkbox" id="pref-sms" /> SMS</label>
    <label class="flex items-center gap-2 text-sm mb-3"><input type="checkbox" id="pref-marketing" /> Marketing opt-in</label>
    <div class="grid sm:grid-cols-2 gap-3 mb-3">
      <label class="block text-xs font-bold text-slate-500">Ngôn ngữ
        <select id="pref-lang" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm">
          <option value="vi">Tiếng Việt</option>
          <option value="en">English</option>
        </select>
      </label>
      <label class="block text-xs font-bold text-slate-500">Múi giờ
        <select id="pref-tz" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm">
          <option value="Asia/Ho_Chi_Minh">Asia/Ho_Chi_Minh</option>
          <option value="Asia/Bangkok">Asia/Bangkok</option>
          <option value="Asia/Singapore">Asia/Singapore</option>
          <option value="UTC">UTC</option>
        </select>
      </label>
    </div>
    <button type="button" id="pref-save-btn"
      class="bg-teal-600 text-white px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest">Lưu</button>
    <p id="pref-msg" class="text-sm mt-2" role="status"></p>
  </section>

  <section class="bg-white rounded-3xl border p-5 mb-6">
    <h2 class="font-bold mb-3">Quyền riêng tư</h2>
    <div class="flex flex-wrap gap-3">
      <button type="button" id="export-data-btn"
        class="bg-slate-800 text-white px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-slate-900">
        Tải dữ liệu của tôi
      </button>
      <button type="button" id="delete-account-btn"
        class="border border-red-300 text-red-700 px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-red-50">
        Yêu cầu xóa tài khoản
      </button>
    </div>
    <p id="privacy-msg" class="text-sm mt-3" role="status"></p>
  </section>
</div>
