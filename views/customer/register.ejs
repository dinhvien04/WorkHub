<div class="max-w-md mx-auto py-8 px-8 border bg-white rounded-[2rem] shadow-2xl">
    <h2 class="text-2xl font-black mb-2 text-slate-800 uppercase tracking-tight text-center">Đăng ký WorkHub</h2>
    <p class="text-slate-400 mb-8 text-sm font-medium italic text-center">Tạo tài khoản để bắt đầu kết nối không gian</p>
    
    <div class="space-y-4">
        <div class="flex gap-3 mb-6">
            <label class="flex-1 cursor-pointer">
                <input type="radio" name="role" value="customer" id="roleCustomer" class="hidden peer" checked onchange="toggleHostFields()">
                <div class="p-4 border-2 border-slate-100 rounded-2xl text-center peer-checked:border-teal-500 peer-checked:bg-teal-50 transition">
                    <span class="block text-xl mb-1">🧑‍💻</span>
                    <span class="block text-[10px] font-black uppercase text-slate-500 peer-checked:text-teal-700">Khách hàng</span>
                </div>
            </label>
            <label class="flex-1 cursor-pointer">
                <input type="radio" name="role" value="host" id="roleHost" class="hidden peer" onchange="toggleHostFields()">
                <div class="p-4 border-2 border-slate-100 rounded-2xl text-center peer-checked:border-indigo-500 peer-checked:bg-indigo-50 transition">
                    <span class="block text-xl mb-1">🏢</span>
                    <span class="block text-[10px] font-black uppercase text-slate-500 peer-checked:text-indigo-700">Chủ cơ sở</span>
                </div>
            </label>
        </div>

        <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
            <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Họ và tên</label>
            <input type="text" id="fullName" placeholder="VD: Nguyễn Văn An" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
        </div>

        <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
            <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Email đăng ký</label>
            <input type="email" id="email" placeholder="example@email.com" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
        </div>

        <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
            <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Mật khẩu</label>
            <input type="password" id="password" placeholder="••••••••" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
        </div>

        <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
            <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Xác nhận mật khẩu</label>
            <input type="password" id="confirmPassword" placeholder="••••••••" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
        </div>

        <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
            <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Số điện thoại / Hotline</label>
            <input type="text" id="phone" placeholder="VD: 0901234567" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
        </div>
        
        <div class="flex gap-2">
            <div class="flex-1 p-3 bg-slate-50 rounded-xl border border-slate-100">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Ngân hàng</label>
                <input type="text" id="bankName" placeholder="VD: Vietcombank" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
            </div>
            <div class="flex-1 p-3 bg-slate-50 rounded-xl border border-slate-100">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Số tài khoản</label>
                <input type="text" id="bankNumber" placeholder="VD: 10123456" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
            </div>
        </div>


        
        <div id="hostFields" class="hidden space-y-4 pt-4 border-t border-slate-100">
            <h3 class="text-xs font-bold text-indigo-600 uppercase">Thông tin doanh nghiệp (Bắt buộc)</h3>
            <div class="p-3 bg-indigo-50/50 rounded-xl border border-indigo-100">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Tên công ty / Cơ sở</label>
                <input type="text" id="companyName" placeholder="VD: WorkHub Center" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
            </div>
            
            <div class="p-3 bg-indigo-50/50 rounded-xl border border-indigo-100">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Mã số thuế</label>
                <input type="text" id="taxCode" placeholder="VD: 0101234567" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
            </div>
            <div class="p-3 bg-indigo-50/50 rounded-xl border border-indigo-100">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Giấy phép kinh doanh (Ảnh/PDF)</label>
                <input type="file" id="verificationDoc" name="verificationDocument" accept=".jpg,.jpeg,.png,.pdf" class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-indigo-100 file:text-indigo-700 hover:file:bg-indigo-200">
            </div>
        </div>

        <button onclick="handleRegister(event)" class="w-full bg-teal-600 text-white py-4 rounded-xl font-bold hover:bg-teal-700 transition uppercase text-xs tracking-widest shadow-lg shadow-teal-100 mt-4">
            Xác nhận đăng ký
        </button>
    </div>

    <div class="mt-8 pt-6 border-t border-slate-100 text-center">
        <a href="/login" class="text-teal-600 font-bold text-sm hover:underline">
            ← Đã có tài khoản? Đăng nhập ngay
        </a>
    </div>
</div>

<script src="/js/register.js"></script>