<div class="max-w-xl mx-auto">
  <h1 class="text-2xl font-black mb-4">Hỗ trợ</h1>
  <form id="support-form" class="bg-white border rounded-3xl p-6 space-y-3">
    <input name="subject" required maxlength="200" placeholder="Tiêu đề" class="w-full border rounded-xl px-3 py-2 text-sm" />
    <textarea name="body" required maxlength="5000" rows="5" placeholder="Mô tả vấn đề" class="w-full border rounded-xl px-3 py-2 text-sm"></textarea>
    <input name="bookingId" placeholder="Booking ID (tuỳ chọn)" class="w-full border rounded-xl px-3 py-2 text-sm" />
    <button class="btn-primary w-full" type="submit">Gửi ticket</button>
    <p id="support-msg" class="text-xs text-slate-500"></p>
  </form>
  <div id="support-list" class="mt-6 space-y-2"></div>
</div>
