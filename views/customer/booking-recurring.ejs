<div class="max-w-2xl mx-auto" id="recurring-page">
  <a href="/booking/wizard" class="text-teal-700 text-sm font-bold hover:underline">← Wizard đơn lẻ</a>
  <h1 class="text-2xl font-black text-slate-800 mt-2 mb-1">Đặt chỗ lặp lại</h1>
  <p class="text-sm text-slate-500 mb-6">Xem trước các lần lặp (daily/weekly) và giá ước tính trước khi tạo series. Tối đa 12 booking mỗi lần.</p>

  <div id="rc-error" class="error-state hidden mb-4" role="alert"></div>

  <section class="bg-white rounded-3xl border p-6 mb-4 space-y-3">
    <label class="block text-xs font-bold text-slate-500">Space ID
      <input id="rc-space" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" placeholder="spaceId" />
    </label>
    <div class="grid sm:grid-cols-2 gap-3">
      <label class="block text-xs font-bold text-slate-500">Tần suất
        <select id="rc-freq" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm">
          <option value="weekly">Weekly</option>
          <option value="daily">Daily</option>
        </select>
      </label>
      <label class="block text-xs font-bold text-slate-500">Interval
        <input id="rc-interval" type="number" min="1" max="8" value="1" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
    </div>
    <label class="block text-xs font-bold text-slate-500">Ngày trong tuần (weekly, 0=CN … 6=T7)
      <input id="rc-dow" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" placeholder="1,3,5" value="1,3,5" />
    </label>
    <div class="grid sm:grid-cols-3 gap-3">
      <label class="block text-xs font-bold text-slate-500">Giờ bắt đầu
        <input id="rc-tod" type="time" value="09:00" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="block text-xs font-bold text-slate-500">Thời lượng (phút)
        <input id="rc-dur" type="number" min="30" step="30" value="120" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="block text-xs font-bold text-slate-500">Số lần
        <input id="rc-count" type="number" min="1" max="12" value="4" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
    </div>
    <label class="block text-xs font-bold text-slate-500">Series start (date)
      <input id="rc-start" type="date" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
    </label>
    <div class="flex gap-2 pt-2">
      <button type="button" id="rc-preview" class="btn-primary flex-1">Xem trước</button>
      <button type="button" id="rc-create" class="flex-1 py-2 rounded-xl bg-slate-800 text-white text-sm font-bold" disabled>Tạo series</button>
    </div>
  </section>

  <section class="bg-white rounded-3xl border p-6 mb-4">
    <h2 class="font-bold mb-2">Preview</h2>
    <p id="rc-est" class="text-sm text-teal-700 font-bold mb-2"></p>
    <ul id="rc-list" class="space-y-1 text-sm text-slate-600"></ul>
  </section>

  <section class="bg-white rounded-3xl border p-6">
    <h2 class="font-bold mb-2">Series của tôi</h2>
    <ul id="rc-mine" class="space-y-2 text-sm"></ul>
  </section>
</div>
