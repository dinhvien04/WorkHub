    <div class="relative h-64 rounded-3xl overflow-hidden mb-10 flex items-center justify-center text-center shadow-lg">
        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=2069"
            class="absolute inset-0 w-full h-full object-cover"
            alt="Văn phòng">

        <div class="absolute inset-0 hero-gradient"></div>

        <div class="relative z-10 text-white p-6">
            <h2 class="text-3xl font-bold mb-2">
                Tìm kiếm không gian làm việc
            </h2>

            <p class="mb-6 opacity-90 font-light text-teal-50">
                Linh hoạt, tiện nghi và chuyên nghiệp
            </p>

            <form action="/search"
                method="GET"
                class="bg-white p-2 rounded-2xl shadow-xl flex gap-2 max-w-xl mx-auto border border-teal-100">

                <input
                    type="text"
                    name="location"
                    placeholder="Bạn muốn làm việc ở đâu?"
                    class="flex-1 px-4 py-2 text-slate-800 rounded-xl focus:outline-none text-sm border-none">

                <button
                    type="submit"
                    class="bg-amber-500 hover:bg-amber-600 text-white px-6 py-2 rounded-xl font-bold transition text-sm">
                    TÌM KIẾM
                </button>

            </form>
        </div>
    </div>

    <h3 class="text-xl font-bold mb-6 text-slate-800 underline decoration-teal-500 decoration-4 underline-offset-8 font-black uppercase tracking-tighter">
        Cơ sở nổi bật
    </h3>

    <div class="grid md:grid-cols-3 gap-6">

        <% if (branches && branches.length > 0) { %>

            <% branches.forEach(branch => { %>

                <div class="bg-white rounded-2xl border p-4 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 shadow-sm flex flex-col">

                    <img
                        src="<%= (branch.Images && branch.Images.length > 0) ? branch.Images[0] : 'https://via.placeholder.com/400x250' %>"
                        class="rounded-xl w-full h-48 object-cover mb-4"
                        alt="<%= branch.Name %>">

                    <div class="flex-1">

                        <h4 class="font-bold text-slate-800 text-lg">
                            <%= branch.Name %>
                        </h4>

                        <p class="text-sm text-slate-500 mt-2">
                            📍 <%= branch.Address %>
                        </p>

                    
                        <% if(branch.Description) { %>
                            <p class="text-sm text-slate-600 mt-3 line-clamp-2">
                                <%= branch.Description %>
                            </p>
                        <% } %>

                        <p class="text-xs text-slate-400 mt-3">
                            🕒 <%= branch.OpeningTime %> - <%= branch.ClosingTime %>
                        </p>

                        <div class="flex items-center gap-1 text-amber-500 text-sm mt-2 font-semibold">
                            ⭐ <%= branch.RatingAvg || 0 %>/5
                        </div>
                        <% if (branch.priceFrom != null) { %>
                        <p class="text-sm font-black text-teal-700 mt-2">Từ <%= Number(branch.priceFrom).toLocaleString('vi-VN') %>đ/giờ</p>
                        <% } %>
                        <% if (branch.hasInstantBook) { %>
                        <span class="wh-badge mt-2">Instant book</span>
                        <% } %>

                    </div>

                    <% 
                      const _href = branch.Slug
                        ? '/khong-gian/' + (branch.CitySlug || 'viet-nam') + '/' + (branch.DistrictSlug || 'khu-vuc') + '/' + branch.Slug
                        : '/detail?branchId=' + branch._id;
                    %>
                    <a href="<%= _href %>"
                    class="w-full py-3 bg-teal-50 text-teal-600 font-bold rounded-xl text-sm text-center mt-4 hover:bg-teal-100 transition">
                        Xem chi tiết
                    </a>

                </div>

            <% }) %>

        <% } else { %>

            <div class="col-span-3 text-center py-10">
                <p class="text-slate-500 italic text-lg">
                    Hiện chưa có cơ sở nào hoạt động.
                </p>
            </div>

        <% } %>

    </div>

    <section id="home-newest" class="hidden mt-12">
      <h3 class="text-xl font-bold mb-4 text-slate-800 uppercase tracking-tighter">Mới trên WorkHub</h3>
      <div data-newest-list class="flex gap-3 overflow-x-auto pb-2"></div>
    </section>