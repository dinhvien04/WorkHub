<div class="max-w-md mx-auto py-10 px-8 border bg-white rounded-[2rem] shadow-2xl transition-all duration-500 animate-fadeInUp">

    <div id="login-form-area" class="animate-fadeIn">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-teal-600 rounded-xl flex items-center justify-center text-white font-black text-xl shadow-lg">W</div>
            <div>
                <h2 class="text-2xl font-black text-slate-800 uppercase tracking-tight" id="login-title">Đăng nhập</h2>
                <p class="text-slate-400 text-sm font-medium" id="login-subtitle">Nhập thông tin tài khoản</p>
            </div>
        </div>

        <div class="space-y-4">
            <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 transition-all duration-200 focus-within:border-teal-400 focus-within:bg-white focus-within:shadow-md">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Email</label>
                <input type="email" id="email" placeholder="name@email.com" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
            </div>
            <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 transition-all duration-200 focus-within:border-teal-400 focus-within:bg-white focus-within:shadow-md">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Mật khẩu</label>
                <input type="password" id="password" placeholder="••••••••" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
            </div>

            <div class="text-right">
                <button type="button" data-wh-click="toggleForgotPasswordForm" data-wh-args="[true]" class="text-xs font-bold text-teal-600 hover:underline transition-colors">Quên mật khẩu?</button>
            </div>

            <button data-wh-click="handleLogin" data-wh-event="1" class="w-full bg-slate-800 text-white py-4 rounded-xl font-bold hover:bg-slate-900 transition-all duration-200 uppercase text-xs tracking-widest shadow-lg mt-4 hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.98]">
                Đăng nhập ngay
            </button>
            <div class="relative my-4 text-center">
              <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-200"></div></div>
              <span class="relative text-[10px] font-black uppercase text-slate-400 bg-white px-3">hoặc</span>
            </div>
            <a href="/api/auth/google" id="google-login-btn"
              class="w-full flex items-center justify-center gap-2 border border-slate-200 bg-white text-slate-800 py-3 rounded-xl font-bold hover:bg-slate-50 hover:shadow-md hover:border-slate-300 transition-all duration-200 text-xs uppercase tracking-widest">
              Đăng nhập với Google
            </a>
            <p id="google-login-hint" class="text-[10px] text-slate-400 text-center mt-2 hidden"></p>
        </div>
        <p class="text-muted text-center mt-6 text-sm text-slate-500">
            Chưa có tài khoản? <a href="/register" class="text-primary font-bold text-teal-600 hover:underline">Đăng ký ngay</a>
        </p>
    </div>

    <div id="forgot-form-area" class="hidden animate-fadeInUp">
        <h2 class="text-2xl font-black mb-2 text-slate-800 uppercase tracking-tight">Khôi phục mật khẩu</h2>
        <p class="text-slate-400 mb-6 text-sm font-medium">Nhập email hệ thống để nhận mã xác minh</p>

        <div class="space-y-4">
            <div id="otp-email-subzone" class="space-y-4">
                <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 transition-all duration-200 focus-within:border-teal-400 focus-within:bg-white focus-within:shadow-md">
                    <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Email khôi phục</label>
                    <input type="email" id="forgot-email" placeholder="name@email.com" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
                </div>
                <button data-wh-click="requestOtpCode" data-wh-event="1" class="w-full bg-teal-600 text-white py-4 rounded-xl font-bold hover:bg-teal-700 transition-all duration-200 uppercase text-xs tracking-widest shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-[0.98]">
                    Gửi mã xác nhận
                </button>
            </div>

            <div id="otp-verify-subzone" class="hidden space-y-4 pt-2">
                <div class="p-3 bg-amber-50 rounded-xl border border-amber-200">
                    <label class="block text-[10px] font-black text-amber-600 uppercase mb-1">Nhập mã OTP (Xem tại Terminal VS Code)</label>
                    <input type="text" id="forgot-otp" placeholder="VD: 123456" class="w-full bg-transparent border-none p-0 text-sm font-black focus:ring-0 outline-none text-slate-800 tracking-widest">
                </div>
                <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
                    <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Mật khẩu mới</label>
                    <input type="password" id="forgot-new-password" placeholder="••••••••" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
                </div>
                <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
                    <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Xác nhận mật khẩu mới</label>
                    <input type="password" id="forgot-confirm-password" placeholder="••••••••" class="w-full bg-transparent border-none p-0 text-sm font-bold focus:ring-0 outline-none text-slate-800">
                </div>
                <button data-wh-click="executeResetPassword" data-wh-event="1" class="w-full bg-indigo-600 text-white py-4 rounded-xl font-bold hover:bg-indigo-700 transition uppercase text-xs tracking-widest shadow-lg">
                    Cập nhật mật khẩu
                </button>
            </div>

            <div class="text-center pt-2">
                <button type="button" data-wh-click="toggleForgotPasswordForm" data-wh-args="[false]" class="text-xs font-bold text-slate-400 hover:text-slate-600">
                    ← Quay lại Đăng nhập
                </button>
            </div>
        </div>
    </div>

</div>

<script src="/js/login.js"></script>