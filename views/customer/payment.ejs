<!-- Xác nhận thanh toán -->
<div class="max-w-4xl">
    <button onclick="goBackToDetail()" class="text-sm font-bold text-slate-500 mb-4 inline-block hover:text-teal-600">← QUAY LẠI THÔNG TIN</button>
    <h2 class="text-3xl font-bold mb-8 text-slate-800">Xác nhận thanh toán</h2>
    <div class="grid md:grid-cols-2 gap-8">
        <div class="space-y-4">
            <div id="pay-30" onclick="setPaymentType('deposit')" class="payment-card p-6 rounded-2xl bg-white shadow-sm border-2 mb-4">
                <div class="flex justify-between items-center">
                    <div>
                        <p class="font-bold text-lg text-slate-800">Đặt cọc (30%)</p>
                    </div>
                    <span class="text-xl font-bold text-teal-600" id="pay-txt-30">--</span>
                </div>
            </div>
            <div id="pay-100" onclick="setPaymentType('full')" class="payment-card p-6 rounded-2xl bg-white shadow-sm border-2">
                <div class="flex justify-between items-center">
                    <div>
                        <p class="font-bold text-lg text-slate-800">Toàn bộ (100%)</p>
                    </div>
                    <span class="text-xl font-bold text-teal-600" id="pay-txt-100">--</span>
                </div>
            </div>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-200 text-center flex flex-col justify-center min-h-[350px]">
            <div id="qr-area" class="hidden">
                <img id="qr-img" src="" class="mx-auto w-44 h-44 mb-4 border p-2 rounded-lg shadow-inner">
                <div class="text-3xl font-black text-teal-600 mb-6" id="qr-price-val">0đ</div>
                <button onclick="handleFinalSuccess()" class="w-full bg-teal-600 text-white py-4 rounded-2xl font-bold shadow-lg hover:bg-teal-700 transition">TÔI ĐÃ CHUYỂN KHOẢN</button>
            </div>
            <div id="qr-placeholder" class="text-slate-400 italic">Vui lòng chọn mức thanh toán để nhận mã QR</div>
        </div>
    </div>
</div>