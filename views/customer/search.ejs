<a href="/"
   class="inline-block mb-4 text-teal-600 font-semibold hover:underline">
    ← Quay lại trang chủ
</a>
<h1 class="text-2xl font-black text-slate-800 mb-2">
    <% if (typeof pageTitle !== 'undefined' && pageTitle && (!keyword || keyword === '')) { %>
      <%= pageTitle.replace(' — WorkHub', '') %>
    <% } else { %>
      Kết quả tìm kiếm: "<span class="text-teal-600"><%= keyword || '' %></span>"
    <% } %>
</h1>
<% if (typeof listingBlurb !== 'undefined' && listingBlurb) { %>
  <p class="text-sm text-slate-600 mb-4 max-w-3xl leading-relaxed"><%= listingBlurb %></p>
<% } else { %>
  <div class="mb-4"></div>
<% } %>

<% if (typeof districtLinks !== 'undefined' && districtLinks && districtLinks.length) { %>
<nav class="mb-6" aria-label="Quận / khu vực">
  <p class="text-[10px] font-black uppercase tracking-wider text-slate-400 mb-2">Khu vực</p>
  <div class="flex flex-wrap gap-2">
    <% districtLinks.forEach(function(d) { %>
      <a href="<%= d.path %>" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-slate-200 bg-white text-slate-700 hover:border-teal-400 hover:text-teal-800">
        <%= d.label %> <span class="text-slate-400">(<%= d.count %>)</span>
      </a>
    <% }) %>
  </div>
</nav>
<% } %>

<div class="flex flex-wrap gap-2 mb-4 text-xs">
  <a href="/booking/wizard" class="px-3 py-1.5 rounded-full bg-teal-50 text-teal-800 font-bold border border-teal-100">Wizard 3 bước</a>
  <a href="/booking/recurring" class="px-3 py-1.5 rounded-full bg-white text-slate-700 font-bold border">Đặt lặp lại</a>
  <a href="/booking/group" class="px-3 py-1.5 rounded-full bg-white text-slate-700 font-bold border">Đặt nhóm</a>
</div>

<form id="search-filters" data-search-form class="bg-white border rounded-2xl p-4 mb-6 grid md:grid-cols-4 gap-3 items-end">
  <div>
    <label class="block text-[10px] font-black uppercase text-slate-400 mb-1" for="sf-location">Từ khóa</label>
    <input id="sf-location" name="location" value="<%= keyword || '' %>" class="w-full border rounded-xl px-3 py-2 text-sm" placeholder="Quận, địa chỉ..." />
  </div>
  <div>
    <label class="block text-[10px] font-black uppercase text-slate-400 mb-1" for="sf-sort">Sắp xếp</label>
    <select id="sf-sort" name="sort" class="w-full border rounded-xl px-3 py-2 text-sm">
      <option value="relevance">Phù hợp</option>
      <option value="near">Gần bạn</option>
      <option value="price_asc">Giá thấp</option>
      <option value="price_desc">Giá cao</option>
      <option value="rating">Rating</option>
      <option value="newest">Mới</option>
    </select>
  </div>
  <div>
    <label class="block text-[10px] font-black uppercase text-slate-400 mb-1" for="sf-radius">Bán kính (km)</label>
    <input id="sf-radius" name="radiusKm" type="number" min="1" max="100" class="w-full border rounded-xl px-3 py-2 text-sm" placeholder="10" />
  </div>
  <div class="flex gap-2">
    <button type="submit" class="bg-teal-600 text-white px-4 py-2 rounded-xl text-xs font-black uppercase flex-1">Tìm</button>
    <button type="button" id="search-near-me" class="border px-3 py-2 rounded-xl text-xs font-black uppercase">Gần tôi</button>
  </div>
  <input type="hidden" name="lat" id="sf-lat" />
  <input type="hidden" name="lng" id="sf-lng" />
</form>

<div id="search-zero" class="hidden bg-amber-50 border border-amber-100 rounded-2xl p-4 mb-6 text-sm">
  <p class="font-bold text-amber-900 mb-2">Không có kết quả — gợi ý</p>
  <ul data-zero-tips class="list-disc pl-5 text-amber-900/80 space-y-1 mb-3"></ul>
  <div data-zero-cities class="flex flex-wrap gap-2 mb-2"></div>
  <div data-zero-actions class="flex flex-wrap gap-2"></div>
</div>
<div id="search-results" class="grid md:grid-cols-3 gap-6 mb-8"></div>

<div class="grid md:grid-cols-3 gap-6">

    <% if (branches && branches.length > 0) { %>

        <% branches.forEach(branch => { %>

            <div class="bg-white rounded-2xl border p-4 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 shadow-sm flex flex-col">

                <img
                    src="<%= (branch.Images && branch.Images.length > 0) ? branch.Images[0] : 'https://via.placeholder.com/400x250' %>"
                    class="rounded-xl w-full h-48 object-cover mb-4"
                    alt="<%= branch.Name %>">

                <div class="flex-1">

                    <h4 class="font-bold text-slate-800 text-lg">
                        <%= branch.Name %>
                    </h4>

                    <p class="text-sm text-slate-500 mt-2">
                        📍 <%= branch.Address %>
                    </p>

                   

                    <% if (branch.Description) { %>
                        <p class="text-sm text-slate-600 mt-3 line-clamp-2">
                            <%= branch.Description %>
                        </p>
                    <% } %>

                    <p class="text-xs text-slate-400 mt-3">
                        🕒 <%= branch.OpeningTime %> - <%= branch.ClosingTime %>
                    </p>

                    <div class="flex items-center gap-1 text-amber-500 text-sm mt-2 font-semibold">
                        ⭐ <%= branch.RatingAvg || 0 %>/5
                    </div>

                </div>

                <%
                  let _detailHref = '/detail?branchId=' + branch._id;
                  if (branch.Slug && branch.CitySlug) {
                    _detailHref = '/khong-gian/' + branch.CitySlug + '/' + (branch.DistrictSlug || 'khu-vuc') + '/' + branch.Slug;
                  }
                %>
                <a href="<%= _detailHref %>"
                   class="w-full py-3 bg-teal-50 text-teal-600 font-bold rounded-xl text-sm text-center mt-4 hover:bg-teal-100 transition">
                    Xem chi tiết
                </a>

            </div>

        <% }) %>

    <% } else { %>

        <div class="col-span-3 text-center py-10">
            <p class="text-slate-500 italic text-lg">
                Không tìm thấy cơ sở nào phù hợp với từ khóa
                "<%= keyword || '' %>"
            </p>
        </div>

    <% } %>

</div>

<% if (typeof relatedGuides !== 'undefined' && relatedGuides && relatedGuides.length) { %>
<section class="mt-10 max-w-4xl">
  <h2 class="font-bold text-lg text-slate-800 mb-3">Hướng dẫn liên quan</h2>
  <ul class="space-y-2">
    <% relatedGuides.forEach(function(g) { %>
      <li>
        <a class="text-teal-700 font-semibold text-sm hover:underline" href="/huong-dan/<%= g.Slug %>"><%= g.Title %></a>
        <% if (g.MetaDescription) { %>
          <p class="text-xs text-slate-500"><%= g.MetaDescription %></p>
        <% } %>
      </li>
    <% }) %>
  </ul>
</section>
<% } %>