<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-black mb-2">Tin nhắn booking</h1>
  <label class="block text-xs font-bold text-slate-500 mb-1">Booking ID</label>
  <div class="flex gap-2 mb-4">
    <input id="msg-booking" class="flex-1 border rounded-xl px-3 py-2 text-sm" placeholder="booking ObjectId" />
    <button type="button" id="msg-load" class="btn-primary">Tải</button>
  </div>
  <div id="msg-list" class="space-y-2 mb-4 min-h-[200px] bg-white border rounded-3xl p-4"></div>
  <div class="flex gap-2">
    <input id="msg-body" class="flex-1 border rounded-xl px-3 py-2 text-sm" placeholder="Nhập tin nhắn..." />
    <button type="button" id="msg-send" class="btn-primary">Gửi</button>
  </div>
</div>
