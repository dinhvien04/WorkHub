<div class="max-w-4xl mx-auto" id="host-ops">
  <h1 class="text-2xl font-black text-slate-800 mb-1">Bulk ops & blackout</h1>
  <p class="text-sm text-slate-500 mb-6">Cập nhật hàng loạt giá/status/amenities; tạo blackout có thông báo khách.</p>
  <div id="ops-msg" class="hidden mb-4 text-sm p-3 rounded-xl border" role="status"></div>

  <section class="bg-white rounded-3xl border p-6 mb-6">
    <h2 class="font-bold mb-3">Bulk update spaces</h2>
    <label class="block text-xs font-bold text-slate-500 mb-1">Space IDs (mỗi dòng hoặc CSV)
      <textarea id="ops-space-ids" rows="3" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm font-mono" placeholder="id1&#10;id2"></textarea>
    </label>
    <div class="grid sm:grid-cols-3 gap-3 mt-3">
      <label class="text-xs font-bold text-slate-500">Status
        <select id="ops-status" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm">
          <option value="">— giữ nguyên —</option>
          <option value="available">available</option>
          <option value="maintenance">maintenance</option>
          <option value="inactive">inactive</option>
        </select>
      </label>
      <label class="text-xs font-bold text-slate-500">Price/hour
        <input id="ops-price" type="number" min="0" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" placeholder="optional" />
      </label>
      <label class="text-xs font-bold text-slate-500">Deposit
        <input id="ops-deposit" type="number" min="0" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" placeholder="optional" />
      </label>
    </div>
    <div class="grid sm:grid-cols-3 gap-3 mt-3">
      <label class="text-xs font-bold text-slate-500 flex items-center gap-2 mt-6">
        <input type="checkbox" id="ops-instant" /> Instant book
      </label>
      <label class="text-xs font-bold text-slate-500">Free cancel hours
        <input id="ops-fc" type="number" min="0" max="168" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">Amenities (comma)
        <input id="ops-amenities" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" placeholder="Wifi, Projector" />
      </label>
    </div>
    <button type="button" id="ops-bulk-btn" class="btn-primary mt-4">Áp dụng bulk</button>
  </section>

  <section class="bg-white rounded-3xl border p-6 mb-6">
    <h2 class="font-bold mb-3">Blackout / maintenance</h2>
    <div class="grid sm:grid-cols-2 gap-3">
      <label class="text-xs font-bold text-slate-500">Space ID
        <input id="bo-space" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">Reason
        <input id="bo-reason" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" value="maintenance" />
      </label>
      <label class="text-xs font-bold text-slate-500">Start
        <input id="bo-start" type="datetime-local" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">End
        <input id="bo-end" type="datetime-local" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
    </div>
    <label class="flex items-center gap-2 text-sm mt-3">
      <input type="checkbox" id="bo-notify" checked /> Thông báo khách có booking chồng
    </label>
    <button type="button" id="bo-create" class="btn-primary mt-3">Tạo blackout</button>
    <div id="bo-alts" class="mt-3 text-xs text-slate-500"></div>
  </section>

  <section class="bg-white rounded-3xl border p-6 mb-6">
    <h2 class="font-bold mb-3">Blackouts hiện có</h2>
    <ul id="bo-list" class="space-y-2 text-sm"></ul>
  </section>

  <section class="bg-white rounded-3xl border p-6 mb-6">
    <h2 class="font-bold mb-3">Add-ons (dịch vụ kèm)</h2>
    <p class="text-xs text-slate-500 mb-3">Khách chọn add-on khi đặt chỗ (wizard). Branch ID để trống = toàn host.</p>
    <div class="grid sm:grid-cols-2 gap-3 mb-3">
      <label class="text-xs font-bold text-slate-500">Tên
        <input id="ao-name" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" placeholder="Nước / Projector" />
      </label>
      <label class="text-xs font-bold text-slate-500">Giá (VND)
        <input id="ao-price" type="number" min="0" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">Đơn vị
        <select id="ao-unit" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm">
          <option value="booking">booking</option>
          <option value="hour">hour</option>
          <option value="person">person</option>
        </select>
      </label>
      <label class="text-xs font-bold text-slate-500">Branch ID (tuỳ chọn)
        <input id="ao-branch" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm font-mono" />
      </label>
      <label class="text-xs font-bold text-slate-500 sm:col-span-2">Mô tả
        <input id="ao-desc" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
    </div>
    <button type="button" id="ao-create" class="btn-primary">Tạo add-on</button>
    <ul id="ao-list" class="mt-4 space-y-2 text-sm"></ul>
  </section>

  <section class="bg-white rounded-3xl border p-6 mb-6">
    <h2 class="font-bold mb-3">Pricing rules</h2>
    <p class="text-xs text-slate-500 mb-3">Tạo draft → Publish khi sẵn sàng. Type: peak_hour, weekend, holiday…</p>
    <div class="grid sm:grid-cols-2 gap-3 mb-3">
      <label class="text-xs font-bold text-slate-500">Tên rule
        <input id="pr-name" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">Type
        <select id="pr-type" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm">
          <option value="peak_hour">peak_hour</option>
          <option value="weekend">weekend</option>
          <option value="holiday">holiday</option>
          <option value="last_minute">last_minute</option>
          <option value="long_stay">long_stay</option>
          <option value="corporate">corporate</option>
        </select>
      </label>
      <label class="text-xs font-bold text-slate-500">Multiplier
        <input id="pr-mult" type="number" step="0.05" min="0" value="1.2" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">Fixed adjust (VND)
        <input id="pr-fixed" type="number" step="1000" value="0" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">Priority (thấp = ưu tiên)
        <input id="pr-prio" type="number" value="100" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">Space ID (tuỳ chọn)
        <input id="pr-space" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm font-mono" />
      </label>
    </div>
    <button type="button" id="pr-create" class="btn-primary">Tạo draft rule</button>
    <ul id="pr-list" class="mt-4 space-y-2 text-sm"></ul>
  </section>

  <section class="bg-white rounded-3xl border p-6 mb-6">
    <h2 class="font-bold mb-3">Space ops (buffer / instant / free-cancel)</h2>
    <p class="text-xs text-slate-500 mb-3">PATCH buffer trước/sau slot, instant book, free cancel hours.</p>
    <div class="grid sm:grid-cols-2 gap-3 mb-3">
      <label class="text-xs font-bold text-slate-500">Space ID
        <input id="so-space" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm font-mono" />
      </label>
      <label class="text-xs font-bold text-slate-500">Buffer before (phút)
        <input id="so-before" type="number" min="0" max="180" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">Cleanup after (phút)
        <input id="so-after" type="number" min="0" max="180" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500">Free cancel hours
        <input id="so-fc" type="number" min="0" max="168" class="mt-1 w-full border rounded-xl px-3 py-2 text-sm" />
      </label>
      <label class="text-xs font-bold text-slate-500 flex items-center gap-2 mt-6">
        <input type="checkbox" id="so-instant" /> Instant book
      </label>
    </div>
    <button type="button" id="so-save" class="btn-primary">Lưu space ops</button>
  </section>

  <section class="bg-white rounded-3xl border p-6">
    <h2 class="font-bold mb-3">Hoàn tiền chờ xử lý (host)</h2>
    <p class="text-xs text-slate-500 mb-3">Duyệt/hoàn offline cần <code>transferReference</code> khi manual.</p>
    <ul id="rf-list" class="space-y-2 text-sm"></ul>
  </section>
</div>
