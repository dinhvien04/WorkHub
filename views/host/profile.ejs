<form id="profile-form" autocomplete="off" onsubmit="event.preventDefault(); updateProfile();"
    enctype="multipart/form-data" class="space-y-6">

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
        <div class="flex items-center gap-3 mb-6 border-b border-slate-50 pb-4">
            <div class="p-2 bg-indigo-50 text-indigo-600 rounded-xl">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
            </div>
            <h3 class="font-black text-base text-slate-800 uppercase tracking-wide">Thông tin chủ sở hữu</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div
                class="p-3 bg-slate-50/70 rounded-xl border border-slate-100 focus-within:border-indigo-500 focus-within:bg-white transition">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1 tracking-wider">Họ và
                    Tên</label>
                <input type="text" id="host-name-input" name="FullName" autocomplete="new-password"
                    class="w-full bg-transparent border-none p-0 text-sm font-semibold focus:ring-0 outline-none text-slate-800"
                    placeholder="Nhập họ và tên">
            </div>

            <div class="p-3 bg-slate-100/50 rounded-xl border border-slate-200 opacity-75">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1 tracking-wider">Email (Không
                    thể sửa)</label>
                <input type="email" id="email" autocomplete="off"
                    class="w-full bg-transparent border-none p-0 text-sm font-semibold outline-none text-slate-500 cursor-not-allowed"
                    disabled>
            </div>

            <div class="md:col-span-2 border border-slate-100 rounded-2xl p-4 bg-slate-50/30">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-bold text-slate-600">Mật khẩu</span>
                    <button type="button" onclick="togglePasswordFields()"
                        class="text-indigo-600 hover:text-indigo-800 font-black text-xs uppercase tracking-wider flex items-center gap-1">
                        ✏️ Thay đổi mật khẩu
                    </button>
                </div>

                <div id="password-fields"
                    class="hidden grid grid-cols-1 md:grid-cols-3 gap-4 pt-2 border-t border-slate-100 border-dashed animate-fade-in">
                    <div
                        class="p-3 bg-white rounded-xl border border-slate-200 focus-within:border-indigo-500 transition">
                        <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Mật khẩu cũ</label>
                        <input type="password" id="old-password" autocomplete="new-password" placeholder="••••••••"
                            class="w-full bg-transparent border-none p-0 text-sm font-semibold focus:ring-0 outline-none">
                    </div>
                    <div
                        class="p-3 bg-white rounded-xl border border-slate-200 focus-within:border-indigo-500 transition">
                        <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Mật khẩu mới</label>
                        <input type="password" id="new-password" autocomplete="new-password" placeholder="••••••••"
                            class="w-full bg-transparent border-none p-0 text-sm font-semibold focus:ring-0 outline-none">
                    </div>
                    <div
                        class="p-3 bg-white rounded-xl border border-slate-200 focus-within:border-indigo-500 transition">
                        <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Xác nhận mật khẩu
                            mới</label>
                        <input type="password" id="confirm-password" autocomplete="new-password" placeholder="••••••••"
                            class="w-full bg-transparent border-none p-0 text-sm font-semibold focus:ring-0 outline-none"
                            oninput="validatePasswordMatch()">
                    </div>
                    <p id="password-error" class="hidden text-xs text-rose-600 font-bold md:col-span-3">
                        ❌ Mật khẩu xác nhận không trùng khớp!</p>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
        <div class="flex items-center gap-3 mb-6 border-b border-slate-50 pb-4">
            <div class="p-2 bg-blue-50 text-blue-600 rounded-xl">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5m0 0V11m0 0h4m-4 0H3m12 0h3M12 7h.01M12 11h.01M12 15h.01M17 11h.01M17 15h.01M7 11h.01M7 15h.01">
                    </path>
                </svg>
            </div>
            <h3 class="font-black text-base text-slate-800 uppercase tracking-wide">Hồ sơ pháp lý & Vận hành</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2 flex items-center gap-6 p-4 bg-slate-50 rounded-2xl border border-slate-100 mb-2">
                <div
                    class="w-20 h-20 bg-white rounded-full border overflow-hidden flex items-center justify-center shadow-sm shrink-0">
                    <img id="logo-preview" src="https://ui-avatars.com/api/?name=Host"
                        class="w-full h-full object-cover" alt="Logo">
                </div>
                <div>
                    <label class="block text-xs font-black text-slate-700 uppercase mb-2">Logo Thương Hiệu</label>
                    <input type="file" name="LogoFile" id="logo-file-input" accept="image/*"
                        onchange="previewImage(event)"
                        class="text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-indigo-50 file:text-indigo-600 hover:file:bg-indigo-100 cursor-pointer">
                    <p class="text-[10px] text-slate-400 mt-1">Chấp nhận file định dạng PNG, JPG, JPEG. Tối đa 2MB.</p>
                </div>
            </div>

            <div
                class="md:col-span-2 p-3 bg-slate-50/70 rounded-xl border border-slate-100 focus-within:border-indigo-500 transition">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1 tracking-wider">Tên Doanh
                    nghiệp</label>
                <input type="text" id="companyName" name="CompanyName" autocomplete="off"
                    class="w-full bg-transparent border-none p-0 text-sm font-semibold focus:ring-0 outline-none text-slate-800"
                    placeholder="Nhập tên doanh nghiệp">
            </div>

            <div
                class="p-3 bg-slate-50/70 rounded-xl border border-slate-100 focus-within:border-indigo-500 transition">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1 tracking-wider">Hotline
                    CSKH</label>
                <input type="text" id="hotline" name="Hotline" autocomplete="off"
                    class="w-full bg-transparent border-none p-0 text-sm font-semibold focus:ring-0 outline-none text-slate-800"
                    placeholder="Số điện thoại hỗ trợ">
            </div>

            <div
                class="p-3 bg-slate-50/70 rounded-xl border border-slate-100 focus-within:border-indigo-500 transition">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1 tracking-wider">Mã số thuế
                    (VAT)</label>
                <input type="text" id="taxCode" name="TaxCode" autocomplete="off"
                    class="w-full bg-transparent border-none p-0 text-sm font-semibold focus:ring-0 outline-none text-slate-800"
                    placeholder="Mã số thuế">
            </div>

            <div
                class="p-3 bg-slate-50/70 rounded-xl border border-slate-100 focus-within:border-indigo-500 transition">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1 tracking-wider">Tên ngân hàng
                    nhận thanh toán</label>
                <input type="text" id="bankName" name="BankName" autocomplete="off"
                    class="w-full bg-transparent border-none p-0 text-sm font-semibold focus:ring-0 outline-none text-slate-800"
                    placeholder="Ví dụ: Vietcombank">
            </div>

            <div
                class="p-3 bg-slate-50/70 rounded-xl border border-slate-100 focus-within:border-indigo-500 transition">
                <label class="block text-[10px] font-black text-slate-400 uppercase mb-1 tracking-wider">Số tài khoản
                    ngân hàng</label>
                <input type="text" id="bankNumber" name="BankNumber" autocomplete="off"
                    class="w-full bg-transparent border-none p-0 text-sm font-semibold focus:ring-0 outline-none text-slate-800"
                    placeholder="Nhập số tài khoản">
            </div>
        </div>

        <div class="mt-8 pt-6 border-t border-slate-100 flex justify-end">
            <button type="submit" id="submit-btn"
                class="bg-indigo-600 hover:bg-indigo-700 text-white px-10 py-3.5 rounded-xl font-bold text-xs uppercase tracking-widest shadow-md transition-all duration-200">
                Lưu thay đổi hồ sơ
            </button>
        </div>
    </div>
</form>

<script src="/js/host-profile.js"></script>