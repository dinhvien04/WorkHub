<div class="flex flex-col gap-6">
    <h2 class="text-3xl font-black text-slate-800 uppercase tracking-tighter mb-4">Lịch sử Giao dịch</h2>
    
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden p-4">
        <div class="flex gap-2 mb-6 bg-slate-50 p-1 rounded-2xl w-fit">
            <button class="px-6 py-2 bg-white rounded-xl text-xs font-black uppercase shadow-sm text-teal-600">Tất cả</button>
            <button class="px-6 py-2 text-slate-400 rounded-xl text-xs font-black uppercase hover:bg-white/50">Chỉ Cọc (30%)</button>
            <button class="px-6 py-2 text-slate-400 rounded-xl text-xs font-black uppercase hover:bg-white/50">Thanh toán Full</button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50 border-b text-[10px] uppercase text-slate-400 font-black tracking-widest">
                    <tr>
                        <th class="p-5">Mã GD / Ngày</th>
                        <th class="p-5">Khách hàng</th>
                        <th class="p-5">Loại thanh toán</th>
                        <th class="p-5">Số tiền</th>
                        <th class="p-5">Cổng TT</th>
                    </tr>
                </thead>
                <tbody class="text-xs">
                    <% const list = typeof payments !== "undefined" ? payments : []; %>
                    
                    <% if (list.length === 0) { %>
                        <tr>
                            <td colspan="5" class="p-10 text-center">
                                <div class="text-4xl mb-4 opacity-20">💳</div>
                                <p class="text-slate-400 font-bold uppercase text-[10px]">Chưa có giao dịch nào</p>
                            </td>
                        </tr>
                    <% } else { %>
                        <% list.forEach(p => { %>
                            <tr class="border-b border-slate-50 hover:bg-slate-50 transition">
                                <td class="p-5">
                                    <p class="font-black text-slate-800"><%= p.TransactionCode || 'TX-UNKNOWN' %></p>
                                    <p class="text-slate-400 font-medium text-[10px]">
                                        <%= p.createdAt ? new Date(p.createdAt).toLocaleString("vi-VN", {hour: '2-digit', minute:'2-digit', day: '2-digit', month: '2-digit', year: '2-digit'}) : "N/A" %>
                                    </p>
                                </td>
                                <td class="p-5 font-bold text-slate-600">
                                    <%= (p.CustomerID && (p.CustomerID.FullName || p.CustomerID.name)) ? (p.CustomerID.FullName || p.CustomerID.name) : "Khách hàng" %>
                                </td>
                                <td class="p-5">
                                    <% if(p.PaymentType === 'deposit' || p.PaymentType === 'cọc') { %>
                                        <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full font-black text-[9px] uppercase border border-amber-200">Đặt cọc (30%)</span>
                                    <% } else if(p.PaymentType === 'full' || p.PaymentType === 'toàn bộ') { %>
                                        <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-black text-[9px] uppercase border border-blue-200">Toàn bộ (100%)</span>
                                    <% } else { %>
                                        <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full font-black text-[9px] uppercase border border-slate-200"><%= p.PaymentType || 'Khác' %></span>
                                    <% } %>
                                </td>
                                <td class="p-5 font-black text-teal-600 text-sm">
                                    + <%= (p.Amount || 0).toLocaleString("vi-VN") %>đ
                                </td>
                                <td class="p-5 font-bold text-slate-400">
                                    <%= p.PaymentMethod || 'Chuyển khoản' %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>