<div class="flex flex-col gap-6">
    <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
            <h2 class="text-3xl font-black text-slate-800 uppercase tracking-tighter">Lịch sử giao dịch</h2>
            <p class="text-sm text-slate-500 mt-1">Chỉ hiển thị giao dịch thuộc host của bạn. Xác minh/từ chối payment pending.</p>
        </div>
    </div>

    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden p-4">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse" id="host-payments-table">
                <thead class="bg-slate-50 border-b text-[10px] uppercase text-slate-400 font-black tracking-widest">
                    <tr>
                        <th class="p-5">Mã GD / Ngày</th>
                        <th class="p-5">Khách hàng</th>
                        <th class="p-5">Loại</th>
                        <th class="p-5">Số tiền</th>
                        <th class="p-5">Trạng thái</th>
                        <th class="p-5 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-xs">
                    <% const list = typeof payments !== "undefined" ? payments : []; %>
                    <% if (list.length === 0) { %>
                        <tr>
                            <td colspan="6" class="p-10 text-center">
                                <div class="text-4xl mb-4 opacity-20">💳</div>
                                <p class="text-slate-400 font-bold uppercase text-[10px]">Chưa có giao dịch nào</p>
                            </td>
                        </tr>
                    <% } else { %>
                        <% list.forEach(p => { %>
                            <tr class="border-b border-slate-50 hover:bg-slate-50 transition" data-payment-id="<%= p._id %>">
                                <td class="p-5">
                                    <p class="font-black text-slate-800"><%= p.TransactionCode || 'TX-UNKNOWN' %></p>
                                    <p class="text-slate-400 font-medium text-[10px]">
                                        <%= p.createdAt ? new Date(p.createdAt).toLocaleString("vi-VN") : "N/A" %>
                                    </p>
                                </td>
                                <td class="p-5 font-bold text-slate-600">
                                    <%= (p.CustomerID && p.CustomerID.FullName) ? p.CustomerID.FullName : "Khách hàng" %>
                                </td>
                                <td class="p-5">
                                    <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full font-black text-[9px] uppercase"><%= p.PaymentType || 'other' %></span>
                                </td>
                                <td class="p-5 font-black text-teal-600 text-sm">
                                    <%= (p.Amount || 0).toLocaleString("vi-VN") %>đ
                                </td>
                                <td class="p-5">
                                    <% if (p.Status === 'successful') { %>
                                        <span class="bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full font-black text-[9px] uppercase">Thành công</span>
                                    <% } else if (p.Status === 'pending') { %>
                                        <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full font-black text-[9px] uppercase">Chờ xác minh</span>
                                    <% } else if (p.Status === 'failed') { %>
                                        <span class="bg-rose-100 text-rose-700 px-3 py-1 rounded-full font-black text-[9px] uppercase">Thất bại</span>
                                    <% } else if (p.Status === 'refunded') { %>
                                        <span class="bg-slate-200 text-slate-700 px-3 py-1 rounded-full font-black text-[9px] uppercase">Đã hoàn</span>
                                    <% } else { %>
                                        <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full font-black text-[9px] uppercase"><%= p.Status %></span>
                                    <% } %>
                                </td>
                                <td class="p-5 text-right">
                                    <% if (p.Status === 'pending') { %>
                                        <button type="button" class="btn-verify-payment bg-teal-600 text-white text-[10px] font-black uppercase px-3 py-2 rounded-xl mr-1" data-id="<%= p._id %>">Xác minh</button>
                                        <button type="button" class="btn-reject-payment bg-rose-50 text-rose-600 text-[10px] font-black uppercase px-3 py-2 rounded-xl border border-rose-100" data-id="<%= p._id %>">Từ chối</button>
                                    <% } else { %>
                                        <span class="text-slate-300 text-[10px]">—</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="/js/host-payments.js"></script>
