# Server
PORT=3000
NODE_ENV=development
# Set to true when behind a reverse proxy (nginx, etc.)
TRUST_PROXY=false

# MongoDB (replica set recommended for multi-document transactions)
# Local: mongodb://127.0.0.1:27017/workhub
# Atlas: mongodb+srv://user:pass@cluster/workhub
MONGODB_URI=mongodb://127.0.0.1:27017/workhub

# REQUIRED — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# Optional session salt (defaults to JWT_SECRET if omitted)
SESSION_SECRET=

# Cloudinary (optional in test; required for production image upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Booking slot granularity in minutes (concurrency lock)
BOOKING_SLOT_MINUTES=30
