# Server
PORT=3000
NODE_ENV=development
TRUST_PROXY=false

# MongoDB (replica set / Atlas recommended when ENABLE_TRANSACTIONS=true)
MONGODB_URI=mongodb://127.0.0.1:27017/workhub

# REQUIRED — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
SESSION_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Booking limits
BOOKING_SLOT_MINUTES=30
MAX_BOOKING_HOURS=24
MAX_BOOKING_DAYS_AHEAD=180

# Multi-document transactions (requires replica set). false for local standalone.
ENABLE_TRANSACTIONS=false

# Email (required in production for password reset)
EMAIL_PROVIDER=
EMAIL_FROM=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Google OIDC (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Dev/test only mock login without real Google:
ALLOW_GOOGLE_MOCK=0

# Web Push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Admin must enable TOTP when 1 (or feature flag admin_require_2fa)
ADMIN_REQUIRE_2FA=0

# Payment gateway mock webhook secret (falls back to JWT_SECRET)
GATEWAY_WEBHOOK_SECRET=
PAYMENT_PROVIDER=workhub_mock
STRIPE_WEBHOOK_SECRET=
MOMO_SECRET_KEY=
