# Server
PORT=3000
NODE_ENV=development
TRUST_PROXY=false

# MongoDB (replica set / Atlas recommended when ENABLE_TRANSACTIONS=true)
MONGODB_URI=mongodb://127.0.0.1:27017/workhub

# REQUIRED — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
SESSION_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Booking limits
BOOKING_SLOT_MINUTES=30
MAX_BOOKING_HOURS=24
MAX_BOOKING_DAYS_AHEAD=180

# Multi-document transactions (requires replica set). false for local standalone.
ENABLE_TRANSACTIONS=false

# Email (required in production for password reset)
# EMAIL_PROVIDER=resend
EMAIL_PROVIDER=
EMAIL_FROM=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
